{
  "api": {
    "auth": {
      "description": "Authentication and user management APIs",
      "base_url": "/api/auth",
      "endpoints": [
        {
          "method": "POST",
          "path": "/register",
          "summary": "Register new user",
          "description": "Create a new user account with email and password",
          "request": {
            "type": "RegisterRequest",
            "fields": [
              {"name": "email", "type": "String", "rules": ["required", "email"]},
              {"name": "password", "type": "String", "rules": ["required", "min:6"]},
              {"name": "name", "type": "String", "rules": ["required"]}
            ]
          },
          "response": {
            "type": "AuthResponse",
            "fields": [
              {"name": "token", "type": "String"},
              {"name": "user", "type": "UserResponse"}
            ]
          }
        },
        {
          "method": "POST",
          "path": "/login",
          "summary": "Login user",
          "description": "Authenticate user and return JWT token",
          "request": {
            "type": "LoginRequest",
            "fields": [
              {"name": "email", "type": "String", "rules": ["required", "email"]},
              {"name": "password", "type": "String", "rules": ["required"]}
            ]
          },
          "response": {
            "type": "AuthResponse",
            "fields": [
              {"name": "token", "type": "String"},
              {"name": "user", "type": "UserResponse"}
            ]
          }
        },
        {
          "method": "GET",
          "path": "/me",
          "summary": "Get current user",
          "description": "Get currently authenticated user information",
          "request": null,
          "response": {
            "type": "UserResponse",
            "fields": [
              {"name": "id", "type": "String"},
              {"name": "email", "type": "String"},
              {"name": "name", "type": "String"},
              {"name": "tier", "type": "UserTier (FREE, PREMIUM)"},
              {"name": "createdAt", "type": "LocalDateTime"}
            ]
          }
        }
      ]
    },
    "subscriptions": {
      "description": "Subscription management APIs",
      "base_url": "/api/subscriptions",
      "endpoints": [
        {
          "method": "GET",
          "path": "",
          "summary": "Get user subscriptions",
          "description": "Get all subscriptions for the authenticated user with optional filters",
          "queryParams": [
            {"name": "status", "type": "SubscriptionStatus (ACTIVE, SUSPENDED, CANCELLED, PENDING_APPROVAL)", "required": false},
            {"name": "isSuspicious", "type": "Boolean", "required": false}
          ],
          "request": null,
          "response": {
            "type": "List<SubscriptionResponse>",
            "itemType": "SubscriptionResponse",
            "fields": [
              {"name": "id", "type": "String"},
              {"name": "userId", "type": "String"},
              {"name": "name", "type": "String"},
              {"name": "icon", "type": "String"},
              {"name": "status", "type": "SubscriptionStatus"},
              {"name": "tier", "type": "UserTier"},
              {"name": "startDate", "type": "LocalDate"},
              {"name": "endDate", "type": "LocalDate"},
              {"name": "renewalDate", "type": "LocalDate"},
              {"name": "isSuspicious", "type": "Boolean"},
              {"name": "suspiciousReason", "type": "String"},
              {"name": "isApproved", "type": "Boolean"},
              {"name": "approvedAt", "type": "LocalDateTime"},
              {"name": "approvedBy", "type": "String"},
              {"name": "amount", "type": "BigDecimal"},
              {"name": "currency", "type": "String"},
              {"name": "billingCycle", "type": "String"},
              {"name": "createdAt", "type": "LocalDateTime"},
              {"name": "updatedAt", "type": "LocalDateTime"}
            ]
          }
        },
        {
          "method": "GET",
          "path": "/suspicious",
          "summary": "Get suspicious subscriptions",
          "description": "Get all subscriptions flagged as suspicious",
          "request": null,
          "response": {
            "type": "List<SubscriptionResponse>",
            "itemType": "SubscriptionResponse"
          }
        },
        {
          "method": "GET",
          "path": "/{id}",
          "summary": "Get subscription details",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": null,
          "response": {
            "type": "SubscriptionResponse"
          }
        },
        {
          "method": "POST",
          "path": "",
          "summary": "Create subscription",
          "request": {
            "type": "SubscriptionRequest",
            "fields": [
              {"name": "name", "type": "String", "rules": ["required"]},
              {"name": "icon", "type": "String"},
              {"name": "tier", "type": "UserTier"},
              {"name": "amount", "type": "BigDecimal", "rules": ["required", ">0"]},
              {"name": "currency", "type": "String", "rules": ["required", "length:3"]},
              {"name": "billingCycle", "type": "String", "rules": ["required"]},
              {"name": "startDate", "type": "LocalDate", "rules": ["required"]}
            ]
          },
          "response": {
            "type": "SubscriptionResponse"
          }
        },
        {
          "method": "PATCH",
          "path": "/{id}/cancel",
          "summary": "Cancel subscription",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": null,
          "response": null
        },
        {
          "method": "PATCH",
          "path": "/{id}/flag",
          "summary": "Flag subscription as suspicious",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": {
            "type": "FlagSuspiciousRequest",
            "fields": [
              {"name": "reason", "type": "String", "rules": ["required"]}
            ]
          },
          "response": {
            "type": "SubscriptionResponse"
          }
        },
        {
          "method": "PATCH",
          "path": "/{id}/approve",
          "summary": "Approve subscription",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": null,
          "response": {
            "type": "SubscriptionResponse"
          }
        }
      ]
    },
    "reminders": {
      "base_url": "/api/reminders",
      "endpoints": [
        {
          "method": "GET",
          "path": "",
          "summary": "Get reminders",
          "queryParams": [
             {"name": "type", "type": "ReminderType (SUBSCRIPTION_RENEWAL, PAYMENT_DUE, TRIAL_ENDING, SUSPICIOUS_ACTIVITY)", "required": false},
             {"name": "isRead", "type": "Boolean", "required": false}
          ],
          "request": null,
          "response": {
            "type": "List<ReminderResponse>",
            "itemType": "ReminderResponse",
            "fields": [
              {"name": "id", "type": "String"},
              {"name": "userId", "type": "String"},
              {"name": "type", "type": "ReminderType"},
              {"name": "title", "type": "String"},
              {"name": "message", "type": "String"},
              {"name": "scheduledAt", "type": "LocalDateTime"},
              {"name": "sentAt", "type": "LocalDateTime"},
              {"name": "isRead", "type": "Boolean"},
              {"name": "metadata", "type": "String"},
              {"name": "createdAt", "type": "LocalDateTime"},
              {"name": "updatedAt", "type": "LocalDateTime"}
            ]
          }
        },
        {
          "method": "POST",
          "path": "",
          "summary": "Create reminder",
          "request": {
            "type": "ReminderRequest",
            "fields": [
              {"name": "type", "type": "ReminderType", "rules": ["required"]},
              {"name": "title", "type": "String", "rules": ["required"]},
              {"name": "message", "type": "String", "rules": ["required"]},
              {"name": "scheduledAt", "type": "LocalDateTime", "rules": ["required", "future"]}
            ]
          },
          "response": {
            "type": "ReminderResponse"
          }
        },
        {
          "method": "PATCH",
          "path": "/{id}",
          "summary": "Update reminder",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": {
            "type": "ReminderUpdateRequest",
            "fields": [
              {"name": "title", "type": "String"},
              {"name": "message", "type": "String"},
              {"name": "scheduledAt", "type": "LocalDateTime", "rules": ["future"]}
            ]
          },
          "response": {
            "type": "ReminderResponse"
          }
        },
        {
          "method": "PATCH",
          "path": "/{id}/read",
          "summary": "Mark reminder as read",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": null,
          "response": null
        },
        {
          "method": "DELETE",
          "path": "/{id}",
          "summary": "Delete reminder",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": null,
          "response": null
        }
      ]
    },
    "transactions": {
      "base_url": "/api/transactions",
      "endpoints": [
        {
          "method": "GET",
          "path": "",
          "summary": "Get transactions",
          "queryParams": [
            {"name": "type", "type": "TransactionType (SUBSCRIPTION_PAYMENT, REFUND, UPGRADE, DOWNGRADE)", "required": false},
            {"name": "status", "type": "TransactionStatus (COMPLETED, PENDING, FAILED, REFUNDED)", "required": false},
            {"name": "page", "type": "int", "default": 0},
            {"name": "size", "type": "int", "default": 10}
          ],
          "request": null,
          "response": {
            "type": "Page<TransactionResponse>",
            "fields": [
              {"name": "content", "type": "List<TransactionResponse>"},
              {"name": "totalPages", "type": "int"},
              {"name": "totalElements", "type": "long"},
              {"name": "size", "type": "int"},
              {"name": "number", "type": "int"}
            ]
          }
        },
        {
          "method": "GET",
          "path": "/{id}",
          "summary": "Get transaction details",
          "pathParams": [{"name": "id", "type": "String"}],
          "request": null,
          "response": {
            "type": "TransactionResponse",
             "fields": [
              {"name": "id", "type": "String"},
              {"name": "userId", "type": "String"},
              {"name": "subscriptionId", "type": "String"},
              {"name": "type", "type": "TransactionType"},
              {"name": "status", "type": "TransactionStatus"},
              {"name": "amount", "type": "BigDecimal"},
              {"name": "currency", "type": "String"},
              {"name": "description", "type": "String"},
              {"name": "metadata", "type": "String"},
              {"name": "createdAt", "type": "LocalDateTime"},
              {"name": "updatedAt", "type": "LocalDateTime"}
            ]
          }
        },
        {
          "method": "POST",
          "path": "",
          "summary": "Create transaction",
          "request": {
            "type": "TransactionRequest",
            "fields": [
              {"name": "subscriptionId", "type": "String"},
              {"name": "type", "type": "TransactionType", "rules": ["required"]},
              {"name": "amount", "type": "BigDecimal", "rules": ["required", ">0"]},
              {"name": "currency", "type": "String", "rules": ["required", "length:3"]},
              {"name": "description", "type": "String"}
            ]
          },
          "response": {
            "type": "TransactionResponse"
          }
        }
      ]
    },
    "analytics": {
      "base_url": "/api/analytics",
      "endpoints": [
        {
          "method": "GET",
          "path": "/subscriptions",
          "summary": "Get subscription metrics",
          "request": null,
          "response": {"type": "Map<String, Object>"}
        },
        {
          "method": "GET",
          "path": "/revenue",
          "summary": "Get revenue metrics",
          "request": null,
          "response": {"type": "Map<String, Object>"}
        },
        {
          "method": "GET",
          "path": "/engagement",
          "summary": "Get user engagement metrics",
          "request": null,
          "response": {"type": "Map<String, Object>"}
        },
        {
          "method": "GET",
          "path": "/conversions",
          "summary": "Get conversion metrics",
          "request": null,
          "response": {"type": "Map<String, Object>"}
        }
      ]
    },
    "conversions": {
      "base_url": "/api/conversions",
      "endpoints": [
        {
          "method": "POST",
          "path": "/upgrade",
          "summary": "Convert to premium",
          "request": {
            "type": "ConversionRequest",
            "fields": [
              {"name": "amount", "type": "BigDecimal", "rules": ["required", ">0"]},
              {"name": "currency", "type": "String", "rules": ["required", "length:3"]},
              {"name": "billingCycle", "type": "String", "rules": ["required"]}
            ]
          },
          "response": {
            "type": "SubscriptionResponse"
          }
        },
        {
          "method": "POST",
          "path": "/downgrade",
          "summary": "Downgrade to free",
          "request": null,
          "response": null
        }
      ]
    }
  },
  "enums": {
    "UserTier": ["FREE", "PREMIUM"],
    "SubscriptionStatus": ["ACTIVE", "SUSPENDED", "CANCELLED", "PENDING_APPROVAL"],
    "ReminderType": ["SUBSCRIPTION_RENEWAL", "PAYMENT_DUE", "TRIAL_ENDING", "SUSPICIOUS_ACTIVITY"],
    "TransactionType": ["SUBSCRIPTION_PAYMENT", "REFUND", "UPGRADE", "DOWNGRADE"],
    "TransactionStatus": ["COMPLETED", "PENDING", "FAILED", "REFUNDED"]
  }
}
